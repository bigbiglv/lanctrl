{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "lanctrl-pc",
  "version": "0.1.0",
  "identifier": "com.lanctrl.lanctrlpc",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI1OTRCMTg0QTE3QTYyQzYKUldUR1lucWhoTEdVSlZBdGZRQTl1OUg4RXI3OEVGWHdEcGsyMnhsUmZFUThLSHhWVmxOTkRhTHIK",
      "endpoints": [
        "https://github.com/bigbiglv/lanctrl/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
